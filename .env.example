# Backend API (plan generation / replace)
# Use localhost only on simulators/emulators.
# For a physical phone, set your laptop LAN IP, e.g. http://10.11.35.244:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# Logging: debug | info | warn | error (defaults: debug in dev, warn in prod builds)
EXPO_PUBLIC_LOG_LEVEL=debug

# Supabase — auth + user_plans sync (see Supabase dashboard for values)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=
