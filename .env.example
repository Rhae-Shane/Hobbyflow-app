# Backend API ? local: localhost/LAN. Shared APK: http://YOUR_DROPLET_IP (port 80 via nginx)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Logging: debug | info | warn | error (defaults: debug in dev, warn in prod builds)
EXPO_PUBLIC_LOG_LEVEL=debug

# Supabase ? auth + client data (anon/publishable key is safe in the app)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Supabase dashboard (shared APK + Google sign-in):
# Authentication ? URL Configuration ? Redirect URLs:
#   hobbyflow://auth/callback
#   hobbyflow://**
# Authentication ? Providers ? Google: enabled
# Storage: post-media + lesson-media buckets (from server migrations)

# Sentry ? client DSN (safe in the app)
EXPO_PUBLIC_SENTRY_DSN=
# Source maps: set SENTRY_AUTH_TOKEN as an EAS secret, then remove SENTRY_DISABLE_AUTO_UPLOAD from eas.json
# SENTRY_AUTH_TOKEN=
