{
  "expo": {
    "name": "HobbyFlow",
    "slug": "hobbyflow-app",
    "scheme": "hobbyflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/hobblyFlow.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo/hobblyFlow.png",
      "resizeMode": "contain",
      "backgroundColor": "#0266FD"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hobbyflow.app"
    },
    "android": {
      "package": "com.hobbyflow.app",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#0266FD",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "hobbyflow",
              "host": "*"
            }
          ]
        }
      ],
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/logo/hobblyFlow.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "useLegacyPackaging": true,
            "enableBundleCompression": true,
            "buildArchs": [
              "arm64-v8a"
            ]
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow HobbyFlow to attach photos and videos to your posts.",
          "cameraPermission": "Allow HobbyFlow to capture photos and videos for your posts."
        }
      ],
      "expo-document-picker",
      "expo-font",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://us.sentry.io/",
          "organization": "hoobyflow",
          "project": "react-native",
          "note": "Use SENTRY_AUTH_TOKEN env to authenticate with Sentry for source maps."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "955273bd-352a-41b9-9da5-1a19528b1e80"
      }
    }
  }
}
